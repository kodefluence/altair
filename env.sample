# App config
APP_ENV=local
ACCESS_TOKEN_TIMEOUT=24h
ACCESS_GRANT_TIMEOUT=2h

# Database configuration. docker-compose.yaml sets MYSQL_ROOT_PASSWORD to
# "root" unconditionally — these vars seed the *non-root* MySQL user that
# the compose entrypoint creates. Do NOT set DATABASE_USERNAME=root:
# MySQL 5.7's entrypoint refuses MYSQL_USER=root and the container will
# crash-loop on first start.
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_NAME=altair_development
DATABASE_USERNAME=altair
DATABASE_PASSWORD=altair

# Basic auth configuration
BASIC_AUTH_USERNAME=altair
BASIC_AUTH_PASSWORD=eaglethatflyinthebluesky

PROXY_HOST=www.local.host

EXAMPLE_USERS_SERVICE_HOST=www.local.host:3000
